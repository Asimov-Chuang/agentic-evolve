{
  "external_directory": "deny",
  "webfetch": "deny",
  "websearch": "deny",
  "task": "deny",
  "read": {
    "*": "deny",
    "**/problem.md": "allow",
    "**/candidate.py": "allow",
    "**/best_program.py": "allow",
    "**/initial_program.py": "allow",
    "**/archive/*/code.py": "allow",
    "**/archive/*/result.json": "allow",
    "**/analyzer.py": "deny",
    "**/_evaluator.py": "deny",
    "**/submit.py": "deny",
    "**/_analyzer_runner.py": "deny",
    "**/_registry.py": "deny",
    "**/workspace_meta.json": "deny",
    "**/checkpoint.json": "deny"
  },
  "edit": {
    "*": "deny",
    "candidate.py": "allow",
    "**/candidate.py": "allow"
  },
  "glob": {
    "*": "allow",
    "**/analyzer.py": "deny",
    "**/_evaluator.py": "deny",
    "**/submit.py": "deny",
    "**/_analyzer_runner.py": "deny",
    "**/_registry.py": "deny",
    "**/workspace_meta.json": "deny",
    "**/checkpoint.json": "deny"
  },
  "grep": {
    "*": "allow",
    "**/analyzer.py": "deny",
    "**/_evaluator.py": "deny",
    "**/submit.py": "deny",
    "NOISE_RATIO": "deny",
    "evaluator_core": "deny"
  },
  "bash": {
    "*": "deny",
    "python submit.py *": "allow",
    "python3 submit.py *": "allow",
    "ls*": "allow",
    "pwd": "allow",
    "echo *": "allow",
    "cat *problem.md*": "allow",
    "cat *candidate.py*": "allow",
    "cat *best_program.py*": "allow",
    "cat *initial_program.py*": "allow",
    "cat *archive/*/code.py*": "allow",
    "cat *archive/*/result.json*": "allow",
    "head *problem.md*": "allow",
    "head *candidate.py*": "allow",
    "head *archive/*/*": "allow",
    "cat *analyzer.py*": "deny",
    "cat *submit.py*": "deny",
    "cat *_evaluator.py*": "deny",
    "cat *workspace_meta.json*": "deny",
    "cat *checkpoint.json*": "deny",
    "cat *_analyzer*": "deny",
    "cat *_registry.py*": "deny",
    "head *analyzer.py*": "deny",
    "head *submit.py*": "deny",
    "head *_evaluator.py*": "deny",
    "less *": "deny",
    "cd ..*": "deny",
    "cd ../..*": "deny"
  }
