{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cloudgpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CloudGPT Chat",
      "options": {
        "baseURL": "http://127.0.0.1:8765/v1",
        "apiKey": "local-proxy"
      },
      "models": {
        "gpt-4o-20241120": {
          "name": "GPT-4o",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-4o-mini-20240718": {
