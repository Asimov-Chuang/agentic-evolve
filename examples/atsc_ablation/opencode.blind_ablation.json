        },
        "gpt-5.4-pro-20260305": {
          "name": "GPT-5.4 Pro",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "gpt-5.4-mini-20260317": {
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 200000,
            "output": 32768
