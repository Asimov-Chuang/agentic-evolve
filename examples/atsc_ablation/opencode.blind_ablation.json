        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "DeepSeek-V4-Pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "grok-code-fast-1": {
          "name": "Grok Code Fast",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-oss-20b": {
