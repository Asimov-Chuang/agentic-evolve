            "context": 128000,
            "output": 16384
          }
        },
        "gpt-oss-120b": {
          "name": "GPT-OSS 120B",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-5.4-mini-20260317": {
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "gpt-5.4-nano-20260317": {
          "name": "GPT-5.4 Nano",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "cloudgpt-codex": {
      "npm": "@ai-sdk/openai",
      "name": "CloudGPT Codex",
      "options": {
        "baseURL": "http://127.0.0.1:8765/v1",
        "apiKey": "local-proxy"
      },
      "models": {
        "gpt-5.3-codex-20260224": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "gpt-5.2-codex-20260114": {
          "name": "GPT-5.2 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "gpt-5.1-codex-20251113": {
          "name": "GPT-5.1 Codex",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "gpt-5.4-20260305": {
          "name": "GPT-5.4",
          "limit": {
            "context": 200000,
            "output": 65536
