          "name": "GPT-5.4 Nano",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "model": "{env:CLOUDGPT_MODEL}",
  "small_model": "{env:CLOUDGPT_SMALL_MODEL}",
  "permission": {
    "external_directory": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "task": "deny",
    "read": {
      "*": "deny",
      "**/problem.md": "allow",
      "**/problem_feedback_meanings.md": "allow",
      "**/candidate.py": "allow",
      "**/best_program.py": "allow",
      "**/initial_program.py": "allow",
      "**/archive/*/code.py": "allow",
      "**/archive/*/result.json": "allow",
      "**/analyzer.py": "deny",
      "**/analyzer_score_only.py": "deny",
      "**/analyzer_feedback_meaning.py": "deny",
      "**/evaluator_stub.py": "deny",
      "**/evaluator_core.py": "deny",
      "**/_private_runner.py": "deny",
      "**/_analyzer_delegate.py": "deny",
      "**/submit.py": "deny",
      "**/_analyzer_runner.py": "deny",
      "**/_registry.py": "deny",
      "**/workspace_meta.json": "deny",
      "**/checkpoint.json": "deny",
      "**/last_eval.json": "deny",
      "**/metrics.json": "deny",
      "**/artifacts.json": "deny",
      "**/raw-artifact.json": "deny"
    },
    "edit": {
      "*": "deny",
      "candidate.py": "allow",
      "**/candidate.py": "allow"
    },
    "glob": {
      "*": "allow",
      "**/analyzer.py": "deny",
      "**/analyzer_score_only.py": "deny",
      "**/analyzer_feedback_meaning.py": "deny",
      "**/evaluator_stub.py": "deny",
      "**/evaluator_core.py": "deny",
      "**/_private_runner.py": "deny",
      "**/_analyzer_delegate.py": "deny",
      "**/submit.py": "deny",
      "**/_analyzer_runner.py": "deny",
      "**/_registry.py": "deny",
      "**/workspace_meta.json": "deny",
      "**/checkpoint.json": "deny",
      "**/last_eval.json": "deny",
      "**/metrics.json": "deny",
      "**/artifacts.json": "deny",
      "**/raw-artifact.json": "deny"
    },
    "grep": {
      "*": "allow",
      "**/analyzer.py": "deny",
      "**/analyzer_score_only.py": "deny",
      "**/analyzer_feedback_meaning.py": "deny",
      "**/evaluator_stub.py": "deny",
      "**/evaluator_core.py": "deny",
      "**/_private_runner.py": "deny",
      "**/_analyzer_delegate.py": "deny",
      "**/submit.py": "deny",
      "evaluator_core": "deny",
      "raw-artifact": "deny",
      "ATSC_ABLATION_EXAMPLE_ROOT": "deny"
    },
    "bash": {
      "*": "deny",
      "python submit.py *": "allow",
      "python3 submit.py *": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "cat *problem.md*": "allow",
      "cat *problem_feedback_meanings.md*": "allow",
      "cat *candidate.py*": "allow",
      "cat *best_program.py*": "allow",
      "cat *initial_program.py*": "allow",
      "cat *archive/*/code.py*": "allow",
      "cat *archive/*/result.json*": "allow",
      "head *problem.md*": "allow",
      "head *problem_feedback_meanings.md*": "allow",
      "head *candidate.py*": "allow",
      "cat *analyzer.py*": "deny",
      "cat *analyzer_score_only.py*": "deny",
      "cat *analyzer_feedback_meaning.py*": "deny",
      "cat *submit.py*": "deny",
      "cat *evaluator_stub.py*": "deny",
      "cat *evaluator_core.py*": "deny",
      "cat *_private_runner.py*": "deny",
      "cat *_analyzer_delegate.py*": "deny",
      "cat *workspace_meta.json*": "deny",
      "cat *checkpoint.json*": "deny",
      "cat *last_eval.json*": "deny",
      "cat *metrics.json*": "deny",
      "cat *artifacts.json*": "deny",
      "cat *raw-artifact.json*": "deny",
      "cat *_analyzer*": "deny",
      "cat *_registry.py*": "deny",
      "less *": "deny",
      "cd ..*": "deny",
      "cd ../..*": "deny"
    }
  }
}
